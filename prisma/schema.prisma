generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 🚀 SAAS ABONELİK PLANLARI (Modelin dışında olmalı)
enum PlanType {
  TRIAL
  BASIC
  PRO
  ULTRA
}

model User {
  id               Int       @id @default(autoincrement())
  email            String    @unique
  hash             String
  firstName        String?
  lastName         String?
  
  // Dükkan Bilgileri
  shopName         String?
  phone            String?
  tagline          String?
  description      String?
  logo             String?
  coverImage       String?
  
  // Adres Bilgileri
  address          String?
  addressTitle     String?
  fullAddress      String?
  city             String?
  district         String?
  
  // Sosyal Medya
  instagram        String?
  facebook         String?
  twitter          String?

  // Çalışma Saatleri
  workStart        String?   @default("09:00")
  workEnd          String?   @default("18:00")
  
  // 🚀 SAAS ABONELİK SİSTEMİ
  plan             PlanType  @default(TRIAL)
  trialEndsAt      DateTime? // Kayıt olunca +30 gün eklenecek
  subscriptionEnd  DateTime? // Ödeme yapınca eklenecek
  isVerified       Boolean   @default(false) // Email onayı
  verificationCode String?   // Maile giden 6 haneli kod
  
  // Mağaza Durumu 
  isActive         Boolean   @default(true)
  isPromoted       Boolean   @default(false)
  isAdmin          Boolean   @default(false)

  // İlişkiler
  services         Service[]
  staffs           Staff[]
  appointments     Appointment[]
  reviews          Review[]
  gallery          Gallery[]
  closures         Closure[]
  leaves           Leave[]
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Service {
  id          Int      @id @default(autoincrement())
  name        String
  duration    Int
  price       Float
  isActive    Boolean  @default(true)
  
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  appointments Appointment[]
}

model Staff {
  id          Int      @id @default(autoincrement())
  name        String
  phone       String?
  email       String?
  imageUrl    String?
  
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  appointments Appointment[]
  leaves       Leave[]
}

model Customer {
  id          Int      @id @default(autoincrement())
  name        String
  phone       String
  notes       String?

  appointments Appointment[]
}

model Appointment {
  id           Int      @id @default(autoincrement())
  dateTime     DateTime
  status       String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED
  cancelReason String?

  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  serviceId    Int
  service      Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  staffId      Int?
  staff        Staff?   @relation(fields: [staffId], references: [id], onDelete: SetNull)

  customerId   Int
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Review {
  id          Int      @id @default(autoincrement())
  rating      Int
  comment     String?
  
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
}

model Gallery {
  id          Int      @id @default(autoincrement())
  imageUrl    String
  modelName   String?
  
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
}

model Closure {
  id          Int      @id @default(autoincrement())
  date        DateTime
  reason      String?
  
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Leave {
  id          Int      @id @default(autoincrement())
  date        DateTime
  
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  staffId     Int
  staff       Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
}