generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 🚀 SAAS ABONELİK PLANLARI
enum PlanType {
  TRIAL
  BASIC
  PRO
  ULTRA
}

model User {
  id               Int       @id @default(autoincrement())
  email            String    @unique
  hash             String
  firstName        String?
  lastName         String?
  
  // Dükkan Bilgileri
  shopName         String?
  phone            String?
  tagline          String?
  description      String?
  logo             String?
  coverImage       String?
  
  // Adres Bilgileri
  address          String?
  addressTitle     String?
  fullAddress      String?
  city             String?
  district         String?
  
  // Sosyal Medya
  instagram        String?
  facebook         String?
  twitter          String?

  // Çalışma Saatleri
  workStart        String?   @default("09:00")
  workEnd          String?   @default("18:00")
  
  // 🚀 SAAS ABONELİK SİSTEMİ
  plan             PlanType  @default(TRIAL)
  trialEndsAt      DateTime? 
  subscriptionEnd  DateTime? 
  isVerified       Boolean   @default(false) 
  verificationCode String?   
  
  // Mağaza Durumu 
  isActive         Boolean   @default(true)
  isPromoted       Boolean   @default(false)
  isAdmin          Boolean   @default(false)

  // İlişkiler (Eski kodlarına uyumlu hale getirildi)
  services         Service[]
  staff            Staff[]
  appointments     Appointment[]
  reviews          Review[]
  galleryItems     GalleryItem[]
  shopClosures     ShopClosure[]
  staffLeaves      StaffLeave[]
  customers        Customer[]
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // 🚀 WhatsApp & SMS Şablonları
  msgTemplateOnay       String? @default("Merhaba [MUSTERI_ADI],\n\n[TARIH] günü saat [SAAT] için [ISLEM] randevunuz başarıyla oluşturulmuştur. ✂️\n\nBizi tercih ettiğiniz için teşekkür ederiz.\n📍 [DUKKAN_ADI]")
  msgTemplateIptal      String? @default("Sayın [MUSTERI_ADI],\n\n[TARIH] - [SAAT] tarihli [ISLEM] randevunuz iptal edilmiştir. Yeni bir randevu oluşturmak için sitemizi ziyaret edebilirsiniz. 😔\n\nİyi günler dileriz.\n📍 [DUKKAN_ADI]")
  msgTemplateHatirlatma String? @default("Merhaba [MUSTERI_ADI]! 🌟\n\nYarın saat [SAAT]'te [ISLEM] randevunuz olduğunu hatırlatmak isteriz. Görüşmek üzere!\n\n📍 [DUKKAN_ADI]")

  resetCode         String?
  resetCodeExpires  DateTime?

  @@map("users")
}

model Service {
  id          Int      @id @default(autoincrement())
  name        String
  duration    Int
  price       Float
  isActive    Boolean  @default(true)
  
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  appointments Appointment[]

  @@map("services")
}

model Staff {
  id          Int      @id @default(autoincrement())
  name        String
  phone       String?
  email       String?
  imageUrl    String?
  
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  appointments Appointment[]
  staffLeaves  StaffLeave[]

  @@map("staffs")
}

model Customer {
  id          Int      @id @default(autoincrement())
  name        String
  phone       String
  notes       String?
  
  // Eski kodundaki userId eklendi
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  appointments Appointment[]

  @@map("customers")
}

model Appointment {
  id             Int      @id @default(autoincrement())
  dateTime       DateTime
  status         String   @default("PENDING") 
  cancelReason   String?
  isReminderSent Boolean  @default(false) // Eksik olan hatırlatıcı eklendi

  userId         Int
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  serviceId      Int
  service        Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  staffId        Int?
  staff          Staff?   @relation(fields: [staffId], references: [id], onDelete: SetNull)

  customerId     Int
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("appointments")
}

model Review {
  id           Int      @id @default(autoincrement())
  rating       Int
  comment      String?
  customerName String? // Eksik olan alan eklendi
  
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime @default(now())

  @@map("reviews")
}

model GalleryItem {
  id          Int      @id @default(autoincrement())
  imageUrl    String
  modelName   String?
  
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())

  @@map("gallery_items")
}

model ShopClosure {
  id          Int      @id @default(autoincrement())
  date        DateTime
  reason      String?
  
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("shop_closures")
}

model StaffLeave {
  id          Int      @id @default(autoincrement())
  date        DateTime
  
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  staffId     Int
  staff       Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@map("staff_leaves")
}